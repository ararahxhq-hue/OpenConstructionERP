{
  "name": "OpenConstructionERP",

  // Layer the dev overlay on top of the repo's existing compose stack.
  // Order matters: later files win on conflicts.
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],

  // The service VS Code attaches to.
  "service": "devcontainer",

  // Only bring up the infra the app actually needs. This deliberately
  // omits the `worker` (builds ./backend) and `qdrant` services from the
  // root compose file so first launch stays fast.
  "runServices": ["postgres", "redis", "minio"],

  "workspaceFolder": "/workspace",

  // Add the Node.js 20 toolchain on top of the Python 3.12 base image.
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  // Forwarded to the host so you can open them in a browser.
  //   8000 backend (FastAPI)   5173 frontend (Vite)
  //   5432 postgres  6379 redis  9000/9001 minio api/console
  "forwardPorts": [8000, 5173, 5432, 6379, 9000, 9001],
  "portsAttributes": {
    "8000": { "label": "backend (FastAPI)" },
    "5173": { "label": "frontend (Vite)" },
    "9001": { "label": "minio console" }
  },

  // Install backend + frontend deps and run DB migrations once, after the
  // container is built.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "remoteUser": "vscode"
}
